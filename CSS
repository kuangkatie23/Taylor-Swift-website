}
.main-image-wrapper {
    position:relative;
    display:flex;
    align-items: center;
    gap: 24px;
}
.main-image-wrapper::before {
    content: "";
    position:absolute;
    top:-60px;
    left: -100px;
    width: 800px;
    height: 400px;
    background-image: url('https://th.bing.com/th/id/R.7eb0e99f4e569638886b21f5f089a333?rik=PstMe2u2kMIGgA&pid=ImgRaw&r=0');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    transform: skew(-20deg, -5deg) rotate(-8deg); 
    z-index: 0;
    opacity: 0.7;    
}
#main-images {
    position: relative;
    z-index: 1;
}
.bio-row::before {
